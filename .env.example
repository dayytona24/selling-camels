# HQ Ranch — environment variables (NAMES ONLY, no real values here).
# Copy to `.env` for local dev, or set these in Railway's variables UI.
# NEVER commit real keys. .env is gitignored.

# --- Supabase ---------------------------------------------------------------
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# SERVICE ROLE key (bypasses RLS). Server-side ONLY — never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (session pooler). Not required by the current
# server code, but kept for migrations / direct SQL tooling.
DATABASE_URL=

# --- House seller -----------------------------------------------------------
# profiles.id that owns every listing. Produced by `npm run seed:house-seller`.
HOUSE_SELLER_ID=
# Optional overrides used only by the seed script:
HOUSE_SELLER_EMAIL=
HOUSE_SELLER_DISPLAY_NAME=
HOUSE_SELLER_PHONE=

# --- Admin (HTTP Basic auth for /api/admin) ---------------------------------
ADMIN_USER=
ADMIN_PASSWORD=

# --- Server -----------------------------------------------------------------
# Port to listen on (Railway sets this automatically).
PORT=
